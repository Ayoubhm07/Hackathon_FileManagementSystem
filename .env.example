# =============================================================================
# DocFlow — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# =============================================================================

# ─── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=docflow_admin
MONGO_ROOT_PASSWORD=change_me_strong_password
MONGO_URI=mongodb://docflow_admin:change_me_strong_password@mongodb:27017/docflow?authSource=admin

# ─── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ROOT_USER=docflow_minio
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# ─── Keycloak (Identity Provider) ─────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_password
KEYCLOAK_REALM=docflow
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_URL_PUBLIC=http://localhost:8080
KEYCLOAK_CLIENT_ID_GATEWAY=api-gateway
KEYCLOAK_CLIENT_SECRET_GATEWAY=change_me_client_secret

# ─── PostgreSQL (Airflow metadata database) ───────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=airflow

# ─── Apache Airflow ───────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_generated_fernet_key_here
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_webserver_secret
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_password

# ─── Service URLs (internal Docker network) ────────────────────────────────────
UPLOAD_SERVICE_URL=http://upload-service:3001
OCR_SERVICE_URL=http://ocr-service:8001
CLASSIFICATION_SERVICE_URL=http://classification-service:8002
EXTRACTION_SERVICE_URL=http://extraction-service:8003
VALIDATION_SERVICE_URL=http://validation-service:3002
AUTH_SERVICE_URL=http://auth-service:8081

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── Frontend (Vite public vars) ───────────────────────────────────────────────
VITE_API_GATEWAY_URL=http://localhost:3000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=docflow

# ─── INSEE SIRENE API (for dataset generation) ────────────────────────────────
SIRENE_API_TOKEN=your_sirene_api_token_here
