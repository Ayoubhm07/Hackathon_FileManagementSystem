# ── INSEE SIRENE API ──────────────────────────────────────────────────────────
# Créer un compte sur https://portail-api.insee.fr/ et souscrire à l'API Sirene
INSEE_CLIENT_ID=your_client_id_here
INSEE_CLIENT_SECRET=your_client_secret_here

# ── YOLOv8 model ─────────────────────────────────────────────────────────────
# Chemin vers votre modèle entraîné. Laisser vide pour le mode texte seul.
YOLO_MODEL_PATH=
# Installer dépendances ML lourdes (spacy model + ultralytics + opencv)
# false = build plus stable/rapide en local
INSTALL_ML=false

# ── Services ─────────────────────────────────────────────────────────────────
EXTRACTION_SERVICE_URL=http://localhost:8001
VALIDATION_SERVICE_URL=http://localhost:8002

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URL="mongodb+srv://username:password@cluster.mongodb.net/documize?retryWrites=true&w=majority"
MONGODB_DB=documize

# ── Frontend / CRM webhook ────────────────────────────────────────────────────
# URL appelée par le DAG Airflow à la fin du pipeline
FRONTEND_WEBHOOK_URL=http://localhost:3000/api/webhooks/document-processed
